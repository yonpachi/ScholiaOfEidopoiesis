    {
      "label": "Go: C版CSV比較テスト (要 monte_carlo.exe)",
      "type": "shell",
      "command": "$env:RUN_C_COMPARE='1'; go test ./... -v -run TestMarginalCSVAgainstC -count=1 -timeout 30m",
      "dependsOn": [],
      "options": {
        "cwd": "${workspaceFolder}/sim",
        "shell": {
          "executable": "powershell.exe",
          "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-Command"]
        }
      },
      "problemMatcher": ["$go"],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
